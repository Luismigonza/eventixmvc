@model EventixMVC.Models.Event

<main>
    <div style="max-width:800px; margin:0 auto;">

        <!-- Botón volver -->
        <a href="/Event/Gallery" style="display:inline-flex; align-items:center; gap:6px;
           color:rgba(255,255,255,0.5); text-decoration:none; font-size:13px; margin-bottom:24px;">
            <i class="material-icons" style="font-size:16px;">arrow_back</i> Volver a la galería
        </a>

        <!-- Imagen principal -->
        @if (!string.IsNullOrEmpty(Model.ImageUrl))
        {
            <img src="@Model.ImageUrl"
                 style="width:100%; height:320px; object-fit:cover; border-radius:16px; margin-bottom:24px;"
                 onerror="this.style.display='none';" />
        }

        <!-- Header del evento -->
        <div style="display:flex; justify-content:space-between; align-items:start; margin-bottom:24px; flex-wrap:wrap; gap:12px;">
            <div>
                <h2 style="font-family:'Bebas Neue',sans-serif; font-size:48px; letter-spacing:2px;
                           color:#fff; margin:0; line-height:1;">
                    @Model.Name
                </h2>
                <p style="color:rgba(255,255,255,0.4); font-size:13px; margin-top:6px;">
                    Publicado el @Model.CreatedAt.ToString("dd/MM/yyyy")
                </p>
            </div>
            <div style="display:flex; flex-direction:column; align-items:flex-end; gap:8px;">
                <span style="background:#E040FB; color:#fff; padding:4px 14px;
                             border-radius:999px; font-size:13px; font-weight:500;">
                    @Model.Category
                </span>
                @{
                    var statusColor = Model.Status == "Activo" ? "#66bb6a" :
                                      Model.Status == "Cancelado" ? "#ef5350" :
                                      Model.Status == "Agotado" ? "#ffa726" : "#888";
                }
                <span style="background:@statusColor; color:#fff; padding:4px 14px;
                             border-radius:999px; font-size:13px; font-weight:500;">
                    @Model.Status
                </span>
            </div>
        </div>

        <!-- Grid de info -->
        <div style="display:grid; grid-template-columns:1fr 1fr; gap:16px; margin-bottom:32px;">
            <div style="background:#1a1a2e; border-radius:12px; padding:20px; border:1px solid #222;">
                <p style="color:#E040FB; font-size:11px; text-transform:uppercase;
                          letter-spacing:1px; margin-bottom:8px;">Fecha y hora</p>
                <p style="color:#fff; font-size:16px; font-weight:500;">
                    @Model.Date.ToString("dd/MM/yyyy")
                </p>
            </div>
            <div style="background:#1a1a2e; border-radius:12px; padding:20px; border:1px solid #222;">
                <p style="color:#E040FB; font-size:11px; text-transform:uppercase;
                          letter-spacing:1px; margin-bottom:8px;">Ubicación</p>
                <p style="color:#fff; font-size:16px; font-weight:500;">@Model.Location</p>
            </div>
            <div style="background:#1a1a2e; border-radius:12px; padding:20px; border:1px solid #222;">
                <p style="color:#E040FB; font-size:11px; text-transform:uppercase;
                          letter-spacing:1px; margin-bottom:8px;">Precio</p>
                <p style="color:#fff; font-size:16px; font-weight:500;">
                    @(Model.Price == 0 ? "Entrada gratuita" : "$" + Model.Price.ToString("N0"))
                </p>
            </div>
            <div style="background:#1a1a2e; border-radius:12px; padding:20px; border:1px solid #222;">
                <p style="color:#E040FB; font-size:11px; text-transform:uppercase;
                          letter-spacing:1px; margin-bottom:8px;">Capacidad</p>
                <p style="color:#fff; font-size:16px; font-weight:500;">
                    @Model.Capacity personas
                </p>
            </div>
            <div style="background:#1a1a2e; border-radius:12px; padding:20px; border:1px solid #222; grid-column:1/-1;">
                <p style="color:#E040FB; font-size:11px; text-transform:uppercase;
                          letter-spacing:1px; margin-bottom:8px;">Organizador</p>
                <p style="color:#fff; font-size:16px; font-weight:500;">@Model.OrganizerName</p>
            </div>
        </div>

        <!-- Descripción -->
        <div style="background:#1a1a2e; border-radius:12px; padding:24px; border:1px solid #222; margin-bottom:32px;">
            <p style="color:#E040FB; font-size:11px; text-transform:uppercase;
                      letter-spacing:1px; margin-bottom:12px;">Descripción</p>
            <p style="color:rgba(255,255,255,0.7); line-height:1.8; font-size:15px;">
                @Model.Description
            </p>
        </div>

    </div>
</main>