@model IEnumerable<EventixMVC.Models.Event>

<div class="row">
    <div class="col s12" style="margin-bottom:20px;">
        <h4 style="color:#E040FB; font-family:'Bebas Neue',sans-serif; letter-spacing:3px;">
            Cartelera de Eventos
        </h4>

        <!-- Filtros por categoría -->
        <div style="display:flex; gap:10px; flex-wrap:wrap; margin-top:10px;">
            <a href="/Event/Gallery" class="btn-small waves-effect"
               style="background-color:#E040FB;">Todos</a>
            <a href="/Event/Gallery?category=Música" class="btn-small waves-effect"
               style="background-color:#333;">Música</a>
            <a href="/Event/Gallery?category=Anime" class="btn-small waves-effect"
               style="background-color:#333;">Anime</a>
            <a href="/Event/Gallery?category=Deportes" class="btn-small waves-effect"
               style="background-color:#333;">Deportes</a>
            <a href="/Event/Gallery?category=Cultural" class="btn-small waves-effect"
               style="background-color:#333;">Cultural</a>
        </div>
    </div>
</div>

<div class="row">
    @foreach (var evento in Model)
    {
        <div class="col s12 m6 l4">
            <div class="card" style="background-color:#1a1a2e; border-radius:12px;">
                <div class="card-image">
                    <img src="@evento.ImageUrl" 
                         style="height:180px; object-fit:cover; border-radius:12px 12px 0 0;"
                         onerror="this.src='https://via.placeholder.com/400x180?text=Sin+imagen'" />
                    <span class="card-title" style="font-family:'Bebas Neue',sans-serif; 
                                                     letter-spacing:2px;">
                        @evento.Name
                    </span>
                </div>
                <div class="card-content" style="color:#ccc;">
                    <p style="margin-bottom:8px;">@evento.Description</p>
                    <p>
                        <i class="material-icons tiny" style="color:#E040FB;">location_on</i>
                        @evento.Location
                    </p>
                    <p>
                        <i class="material-icons tiny" style="color:#E040FB;">event</i>
                        @evento.Date.ToString("dd/MM/yyyy")
                    </p>
                </div>
                <div class="card-action" style="border-top:1px solid #333;">
                    <span class="new badge" style="background-color:#E040FB; float:left; 
                                                    position:relative; margin:4px 0;"
                          data-badge-caption="">
                        @evento.Category
                    </span>
                </div>
            </div>
        </div>
    }

    @if (!Model.Any())
    {
        <div class="col s12" style="text-align:center; padding:60px 0; color:#666;">
            <i class="material-icons" style="font-size:48px;">event_busy</i>
            <p style="margin-top:10px;">No hay eventos en esta categoría.</p>
        </div>
    }
</div>