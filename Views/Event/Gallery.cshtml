@model IEnumerable<EventixMVC.Models.Event>

<!-- Hero -->
<div class="hero">
    <h1>CARTE<span>LERA</span></h1>
    <p>Descubre los mejores eventos cerca de ti</p>
    <div class="hero-stats">
        <div class="hero-stat">
            <div class="number">@Model.Count()</div>
            <div class="label">Eventos activos</div>
        </div>
        <div class="hero-stat">
            <div class="number">@Model.Select(e => e.Category).Distinct().Count()</div>
            <div class="label">Categorías</div>
        </div>
        <div class="hero-stat">
            <div class="number">@Model.Count(e => e.Date >= DateTime.Today)</div>
            <div class="label">Próximos eventos</div>
        </div>
    </div>
</div>

<main>
    <!-- Filtros -->
    <div style="display:flex; gap:10px; flex-wrap:wrap; margin-bottom:32px; align-items:center;">
        <span style="color:rgba(255,255,255,0.4); font-size:13px; margin-right:4px;">Filtrar:</span>
        <a href="/Event/Gallery"
           style="padding:6px 18px; border-radius:999px; font-size:13px; font-weight:500; text-decoration:none;
                  background-color:@(string.IsNullOrEmpty(Context.Request.Query["category"].ToString()) ? "#E040FB" : "#1a1a2e");
                  color:@(string.IsNullOrEmpty(Context.Request.Query["category"].ToString()) ? "#fff" : "rgba(255,255,255,0.6)");
                  border: 1px solid @(string.IsNullOrEmpty(Context.Request.Query["category"].ToString()) ? "#E040FB" : "#333");">
            Todos
        </a>
        @foreach (var cat in new[] { "Música", "Anime", "Deportes", "Cultural" })
        {
            <a href="/Event/Gallery?category=@cat"
               style="padding:6px 18px; border-radius:999px; font-size:13px; font-weight:500; text-decoration:none;
                      background-color:@(Context.Request.Query["category"] == cat ? "#E040FB" : "#1a1a2e");
                      color:@(Context.Request.Query["category"] == cat ? "#fff" : "rgba(255,255,255,0.6)");
                      border: 1px solid @(Context.Request.Query["category"] == cat ? "#E040FB" : "#333");">
                @cat
            </a>
        }
    </div>

    <!-- Cards -->
    <div style="display:grid; grid-template-columns:repeat(auto-fill, minmax(300px, 1fr)); gap:24px;">
        @foreach (var evento in Model)
        {
            <div style="background:#1a1a2e; border-radius:16px; overflow:hidden; border:1px solid #222;
                        transition:transform 0.2s, border-color 0.2s;"
                 onmouseover="this.style.transform='translateY(-4px)'; this.style.borderColor='#E040FB';"
                 onmouseout="this.style.transform='translateY(0)'; this.style.borderColor='#222';">

                <!-- Imagen -->
                @if (!string.IsNullOrEmpty(evento.ImageUrl))
                {
                    <img src="@evento.ImageUrl"
                         style="width:100%; height:200px; object-fit:cover;"
                         onerror="this.style.display='none'; this.nextElementSibling.style.display='flex';" />
                }
                <div style="height:200px; background:#252540; display:@(string.IsNullOrEmpty(evento.ImageUrl) ? "flex" : "none");
                            align-items:center; justify-content:center;">
                    <i class="material-icons" style="font-size:56px; color:#333;">image_not_supported</i>
                </div>

                <!-- Contenido -->
                <div style="padding:20px;">
                    <div style="display:flex; justify-content:space-between; align-items:start; margin-bottom:12px;">
                        <h5 style="font-family:'Bebas Neue',sans-serif; font-size:22px;
                                   letter-spacing:1px; color:#fff; margin:0; line-height:1.2;">
                            @evento.Name
                        </h5>
                        <span style="background:#E040FB; color:#fff; padding:3px 10px;
                                     border-radius:999px; font-size:11px; font-weight:500; white-space:nowrap; margin-left:8px;">
                            @evento.Category
                        </span>
                    </div>

                    <p style="color:rgba(255,255,255,0.5); font-size:13px; margin-bottom:16px; line-height:1.5;">
                        @(evento.Description.Length > 80 ? evento.Description.Substring(0, 80) + "..." : evento.Description)
                    </p>

                    <div style="display:flex; flex-direction:column; gap:6px; margin-bottom:16px;">
                        <span style="font-size:12px; color:rgba(255,255,255,0.5); display:flex; align-items:center; gap:6px;">
                            <i class="material-icons" style="font-size:14px; color:#E040FB;">location_on</i>
                            @evento.Location
                        </span>
                        <span style="font-size:12px; color:rgba(255,255,255,0.5); display:flex; align-items:center; gap:6px;">
                            <i class="material-icons" style="font-size:14px; color:#E040FB;">event</i>
                            @evento.Date.ToString("dd/MM/yyyy")
                        </span>
                        <span style="font-size:12px; color:rgba(255,255,255,0.5); display:flex; align-items:center; gap:6px;">
                            <i class="material-icons" style="font-size:14px; color:#E040FB;">confirmation_number</i>
                            @(evento.Price == 0 ? "Entrada gratuita" : "$" + evento.Price.ToString("N0"))
                        </span>
                    </div>

                    <a href="/Event/Detail/@evento.Id"
                       style="display:block; text-align:center; padding:10px; background:#E040FB;
                              color:#fff; border-radius:8px; font-size:13px; font-weight:500;
                              text-decoration:none; transition:background 0.2s;"
                       onmouseover="this.style.background='#c000d0';"
                       onmouseout="this.style.background='#E040FB';">
                        Ver más info
                    </a>
                </div>
            </div>
        }

        @if (!Model.Any())
        {
            <div style="grid-column:1/-1; text-align:center; padding:80px 0; color:#444;">
                <i class="material-icons" style="font-size:64px;">event_busy</i>
                <p style="margin-top:12px; font-size:16px;">No hay eventos en esta categoría.</p>
            </div>
        }
    </div>
</main>