@model EventixMVC.Models.Event

<main>
    <div style="max-width:700px; margin:0 auto;">

        <a href="/Event/Index" style="display:inline-flex; align-items:center; gap:6px;
           color:rgba(255,255,255,0.5); text-decoration:none; font-size:13px; margin-bottom:24px;">
            <i class="material-icons" style="font-size:16px;">arrow_back</i> Volver al panel
        </a>

        <h4 style="font-family:'Bebas Neue',sans-serif; letter-spacing:2px;
                   color:#E040FB; margin-bottom:24px;">Editar Evento</h4>

        <div style="background:#1a1a2e; border-radius:16px; padding:32px; border:1px solid #222;">
            <form asp-action="Update" method="post">
                <input type="hidden" asp-for="Id" />
                <input type="hidden" asp-for="CreatedAt" />

                <div style="display:grid; grid-template-columns:1fr 1fr; gap:20px;">

                    <div style="display:flex; flex-direction:column; gap:6px;">
                        <label style="font-size:12px; color:#E040FB; text-transform:uppercase; letter-spacing:1px;">Nombre *</label>
                        <input asp-for="Name" type="text"
                               style="background:#252540; border:1px solid #333; border-radius:8px;
                                      padding:10px 14px; color:#fff; font-size:14px; outline:none; font-family:'DM Sans',sans-serif;" />
                        <span asp-validation-for="Name" style="font-size:12px; color:#ef5350;"></span>
                    </div>

                    <div style="display:flex; flex-direction:column; gap:6px;">
                        <label style="font-size:12px; color:#E040FB; text-transform:uppercase; letter-spacing:1px;">Categoría *</label>
                        <select asp-for="Category" class="browser-default"
                                style="background:#252540; border:1px solid #333; border-radius:8px;
                                       padding:10px 14px; color:#fff; font-size:14px; width:100%; font-family:'DM Sans',sans-serif;">
                            <option value="Música">Música</option>
                            <option value="Anime">Anime</option>
                            <option value="Deportes">Deportes</option>
                            <option value="Cultural">Cultural</option>
                        </select>
                        <span asp-validation-for="Category" style="font-size:12px; color:#ef5350;"></span>
                    </div>

                    <div style="display:flex; flex-direction:column; gap:6px;">
                        <label style="font-size:12px; color:#E040FB; text-transform:uppercase; letter-spacing:1px;">Fecha *</label>
                        <input asp-for="Date" type="date"
                               style="background:#252540; border:1px solid #333; border-radius:8px;
                                      padding:10px 14px; color:#fff; font-size:14px; outline:none; color-scheme:dark;" />
                        <span asp-validation-for="Date" style="font-size:12px; color:#ef5350;"></span>
                    </div>

                    <div style="display:flex; flex-direction:column; gap:6px;">
                        <label style="font-size:12px; color:#E040FB; text-transform:uppercase; letter-spacing:1px;">Ubicación *</label>
                        <input asp-for="Location" type="text"
                               style="background:#252540; border:1px solid #333; border-radius:8px;
                                      padding:10px 14px; color:#fff; font-size:14px; outline:none; font-family:'DM Sans',sans-serif;" />
                        <span asp-validation-for="Location" style="font-size:12px; color:#ef5350;"></span>
                    </div>

                    <div style="display:flex; flex-direction:column; gap:6px;">
                        <label style="font-size:12px; color:#E040FB; text-transform:uppercase; letter-spacing:1px;">Precio</label>
                        <input asp-for="Price" type="number" min="0"
                               style="background:#252540; border:1px solid #333; border-radius:8px;
                                      padding:10px 14px; color:#fff; font-size:14px; outline:none; font-family:'DM Sans',sans-serif;" />
                        <span asp-validation-for="Price" style="font-size:12px; color:#ef5350;"></span>
                    </div>

                    <div style="display:flex; flex-direction:column; gap:6px;">
                        <label style="font-size:12px; color:#E040FB; text-transform:uppercase; letter-spacing:1px;">Capacidad</label>
                        <input asp-for="Capacity" type="number" min="1"
                               style="background:#252540; border:1px solid #333; border-radius:8px;
                                      padding:10px 14px; color:#fff; font-size:14px; outline:none; font-family:'DM Sans',sans-serif;" />
                        <span asp-validation-for="Capacity" style="font-size:12px; color:#ef5350;"></span>
                    </div>

                    <div style="display:flex; flex-direction:column; gap:6px;">
                        <label style="font-size:12px; color:#E040FB; text-transform:uppercase; letter-spacing:1px;">Organizador *</label>
                        <input asp-for="OrganizerName" type="text"
                               style="background:#252540; border:1px solid #333; border-radius:8px;
                                      padding:10px 14px; color:#fff; font-size:14px; outline:none; font-family:'DM Sans',sans-serif;" />
                        <span asp-validation-for="OrganizerName" style="font-size:12px; color:#ef5350;"></span>
                    </div>

                    <div style="display:flex; flex-direction:column; gap:6px;">
                        <label style="font-size:12px; color:#E040FB; text-transform:uppercase; letter-spacing:1px;">Estado</label>
                        <select asp-for="Status" class="browser-default"
                                style="background:#252540; border:1px solid #333; border-radius:8px;
                                       padding:10px 14px; color:#fff; font-size:14px; width:100%; font-family:'DM Sans',sans-serif;">
                            <option value="Activo">Activo</option>
                            <option value="Cancelado">Cancelado</option>
                            <option value="Agotado">Agotado</option>
                            <option value="Inactivo">Inactivo</option>
                        </select>
                    </div>

                    <div style="display:flex; flex-direction:column; gap:6px; grid-column:1/-1;">
                        <label style="font-size:12px; color:#E040FB; text-transform:uppercase; letter-spacing:1px;">Descripción *</label>
                        <textarea asp-for="Description" rows="4"
                                  style="background:#252540; border:1px solid #333; border-radius:8px;
                                         padding:10px 14px; color:#fff; font-size:14px; outline:none;
                                         font-family:'DM Sans',sans-serif; resize:vertical;"></textarea>
                        <span asp-validation-for="Description" style="font-size:12px; color:#ef5350;"></span>
                    </div>

                    <div style="display:flex; flex-direction:column; gap:6px; grid-column:1/-1;">
                        <label style="font-size:12px; color:#E040FB; text-transform:uppercase; letter-spacing:1px;">URL del póster</label>
                        <input asp-for="ImageUrl" type="url"
                               style="background:#252540; border:1px solid #333; border-radius:8px;
                                      padding:10px 14px; color:#fff; font-size:14px; outline:none; font-family:'DM Sans',sans-serif;" />
                    </div>

                </div>

                <div style="display:flex; gap:12px; margin-top:28px;">
                    <button type="submit"
                            style="padding:12px 28px; background:#E040FB; color:#fff; border:none;
                                   border-radius:8px; font-size:14px; font-weight:500; cursor:pointer; font-family:'DM Sans',sans-serif;">
                        <i class="material-icons" style="font-size:16px; vertical-align:middle; margin-right:6px;">save</i>
                        Actualizar evento
                    </button>
                    <a href="/Event/Index"
                       style="padding:12px 28px; background:#252540; color:rgba(255,255,255,0.6);
                              border-radius:8px; font-size:14px; text-decoration:none; display:flex; align-items:center;">
                        Cancelar
                    </a>
                </div>

            </form>
        </div>
    </div>
</main>

@section Scripts {
<script>
document.addEventListener('DOMContentLoaded', function () {
    const errors = document.querySelectorAll('[data-valmsg-for]');
    errors.forEach(e => {
        if (e.textContent.trim() !== '')
            showToast(e.textContent.trim(), 'error');
    });
});
</script>
}