@model EventixMVC.Models.Event

<div class="row">
    <div class="col s12 m8 offset-m2">

        <h5 style="color:#E040FB; font-family:'Bebas Neue',sans-serif; 
                   letter-spacing:2px; margin-bottom:24px;">
            Editar Evento
        </h5>

        <div style="background:#1a1a2e; border-radius:12px; padding:30px;">
            <form asp-action="Update" method="post">

                <input type="hidden" asp-for="Id" />

                <div class="row">
                    <div class="input-field col s12 m6">
                        <input asp-for="Name" id="Name" type="text"
                               style="color:#fff; border-bottom-color:#555;" />
                        <label for="Name" class="active" style="color:#aaa;">Nombre del evento</label>
                    </div>
                    <div class="input-field col s12 m6">
                        <select asp-for="Category" id="Category" class="browser-default"
                                style="background:#252540; color:#fff; border:none;
                                       border-bottom:1px solid #555; padding:8px;
                                       width:100%; margin-top:16px; border-radius:4px;">
                            <option value="">Selecciona categoría</option>
                            <option value="Música">Música</option>
                            <option value="Anime">Anime</option>
                            <option value="Deportes">Deportes</option>
                            <option value="Cultural">Cultural</option>
                        </select>
                    </div>
                </div>

                <div class="row">
                    <div class="input-field col s12 m6">
                        <input asp-for="Date" id="Date" type="date"
                               style="color:#fff; border-bottom-color:#555;" />
                        <label for="Date" class="active" style="color:#aaa;">Fecha</label>
                    </div>
                    <div class="input-field col s12 m6">
                        <input asp-for="Location" id="Location" type="text"
                               style="color:#fff; border-bottom-color:#555;" />
                        <label for="Location" class="active" style="color:#aaa;">Ubicación</label>
                    </div>
                </div>

                <div class="row">
                    <div class="input-field col s12">
                        <textarea asp-for="Description" id="Description"
                                  class="materialize-textarea"
                                  style="color:#fff; border-bottom-color:#555;"></textarea>
                        <label for="Description" class="active" style="color:#aaa;">Descripción</label>
                    </div>
                </div>

                <div class="row">
                    <div class="input-field col s12">
                        <input asp-for="ImageUrl" id="ImageUrl" type="url"
                               style="color:#fff; border-bottom-color:#555;" />
                        <label for="ImageUrl" class="active" style="color:#aaa;">URL del póster / imagen</label>
                    </div>
                </div>

                <div style="display:flex; gap:12px; margin-top:10px;">
                    <button type="submit" class="btn waves-effect waves-light"
                            style="background-color:#E040FB;">
                        <i class="material-icons left">save</i>Actualizar
                    </button>
                    <a href="/Event/Index" class="btn waves-effect"
                       style="background-color:#333;">
                        <i class="material-icons left">arrow_back</i>Cancelar
                    </a>
                </div>

            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            var elems = document.querySelectorAll('select');
            M.FormSelect.init(elems);
        });
    </script>
}