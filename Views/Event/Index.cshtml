@model IEnumerable<EventixMVC.Models.Event>

<div class="row">
    <div class="col s12">
        <div style="display:flex; justify-content:space-between; align-items:center; margin-bottom:20px;">
            <h5 style="color:#E040FB; font-family:'Bebas Neue',sans-serif; letter-spacing:2px;">
                Panel de Administración
            </h5>
            <a href="/Event/Create" class="btn waves-effect waves-light" 
               style="background-color:#E040FB;">
                <i class="material-icons left">add</i>Nuevo Evento
            </a>
        </div>

        <table class="striped responsive-table" style="background:#1a1a2e; border-radius:8px;">
            <thead>
                <tr style="border-bottom: 1px solid #333;">
                    <th style="color:#E040FB;">Nombre</th>
                    <th style="color:#E040FB;">Fecha</th>
                    <th style="color:#E040FB;">Ubicación</th>
                    <th style="color:#E040FB;">Categoría</th>
                    <th style="color:#E040FB;">Acciones</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var evento in Model)
                {
                    <tr style="border-bottom: 1px solid #222;">
                        <td style="color:#fff;">@evento.Name</td>
                        <td style="color:#aaa;">@evento.Date.ToString("dd/MM/yyyy")</td>
                        <td style="color:#aaa;">@evento.Location</td>
                        <td>
                            <span class="new badge" style="background-color:#E040FB;" 
                                  data-badge-caption="">
                                @evento.Category
                            </span>
                        </td>
                        <td>
                            <a href="/Event/Edit/@evento.Id" 
                               class="btn-small waves-effect" 
                               style="background-color:#333; margin-right:5px;">
                                <i class="material-icons">edit</i>
                            </a>
                            <form action="/Event/Delete" method="post" style="display:inline;">
                                <input type="hidden" name="id" value="@evento.Id" />
                                <button type="submit" class="btn-small waves-effect"
                                        style="background-color:#c62828;"
                                        onclick="return confirm('¿Eliminar este evento?')">
                                    <i class="material-icons">delete</i>
                                </button>
                            </form>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>